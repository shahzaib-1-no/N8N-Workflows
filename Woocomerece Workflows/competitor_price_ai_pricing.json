    {
      "parameters": {
        "promptType": "define",
        "text": "=Product: {{ $json.name }} (ID: {{ $json.id }}, SKU: {{ $json.sku }})\nCurrent Regular Price: {{ $json.regular_price }}\nCurrent Sale Price: {{ $json.sale_price }}\nStock Quantity: {{ $json.stock_quantity }}\nSales Velocity (units/day, last 30d): {{ $json.total_sales ? Math.round($json.total_sales / 30) : 'unknown' }}\nProduct Cost (COGS): {{ $json.cost || 'unknown' }}\n\nCompetitor Data:\n{{ JSON.stringify($('Fetch Competitor Prices').item.json, null, 2) }}\n\nAnalyze the situation and return ONLY a valid JSON object with these fields:\n{\n  \"new_price\": \"<string: recommended new regular price>\",\n  \"flash_sale_active\": <boolean>,\n  \"discount_percent\": <number 0-30>,\n  \"sale_price\": \"<string: sale price if flash_sale_active else empty string>\",\n  \"reasoning\": \"<1-2 sentence explanation>\"\n}",
        "options": {
          "maxIterations": 5
        }
      },
      "id": "4cf4ec7d-580b-451b-8887-4a621ba9bfcf",
      "name": "AI Pricing Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2,
      "position": [
        480,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "// =============================================================\n// VALIDATION + ROLLBACK GUARD\n// Parses AI response and enforces business rules.\n// =============================================================\nconst MIN_MARGIN = 0.20;   // 20% minimum margin\nconst MAX_DISCOUNT = 30;   // 30% max discount\n\n// 1. Pull the AI output. AI Agent typically nests it under .output\nconst aiRaw = $input.first().json;\nconst productCtx = $('Fetch Competitor Prices').item.json;\n\n// Pull original product context from earlier node (batch item)\nconst batchItem = $('Process Per Product').item.json;\n\nlet parsed = null;\nconst candidate = aiRaw.output || aiRaw.text || JSON.stringify(aiRaw);\ntry {\n  // Extract JSON block if AI wrapped it in prose\n  const m = candidate.match(/\\{[\\s\\S]*\\}/);\n  parsed = m ? JSON.parse(m[0]) : null;\n} catch (e) {\n  parsed = null;\n}\n\nconst errors = [];\n\nif (!parsed) {\n  errors.push('AI response could not be parsed as JSON');\n} else {\n  const newPrice = parseFloat(parsed.new_price);\n  const salePrice = parseFloat(parsed.sale_price || '0');\n  const discount = parseFloat(parsed.discount_percent || '0');\n  const cost = parseFloat(batchItem.cost || batchItem.meta_data?.find(m => m.key === 'cost')?.value || '0');\n\n  // Sanity checks\n  if (isNaN(newPrice) || newPrice <= 0) {\n    errors.push(`new_price invalid: ${parsed.new_price}`);\n  }\n  if (isNaN(discount) || discount < 0 || discount > MAX_DISCOUNT) {\n    errors.push(`discount_percent out of bounds (0-${MAX_DISCOUNT}): ${parsed.discount_percent}`);\n  }\n  if (cost > 0 && !isNaN(newPrice)) {\n    const margin = (newPrice - cost) / newPrice;\n    if (margin < MIN_MARGIN) {\n      errors.push(`margin ${(margin*100).toFixed(1)}% below minimum ${(MIN_MARGIN*100).toFixed(0)}% (cost=${cost})`);\n    }\n  }\n  if (parsed.flash_sale_active && (!isNaN(salePrice) && salePrice >= newPrice)) {\n    errors.push(`sale_price must be < new_price when flash_sale_active`);\n  }\n}\n\nreturn [{\n  json: {\n    is_valid: errors.length === 0,\n    errors: errors,\n    product_id: batchItem.id,\n    sku: batchItem.sku,\n    product_name: batchItem.name,\n    current_regular_price: batchItem.regular_price,\n    current_sale_price: batchItem.sale_price,\n    ai_decision: parsed,\n    timestamp: new Date().toISOString()\n  }\n}];\n"
      },
