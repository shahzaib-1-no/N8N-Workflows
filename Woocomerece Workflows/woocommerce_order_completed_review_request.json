    {
      "parameters": {
        "jsCode": "const order = $('Order Completed Trigger').item.json;\nconst product = $input.first().json;\nconst cats = (product.categories || []).map(c => (c.name || '').toLowerCase()).join(' ');\nlet delayDays = 5; // default: physical products 3-7 days\nlet categoryType = 'physical';\nif (/beauty|cosmetic|food|consumable|skincare|supplement/.test(cats)) { delayDays = 2; categoryType = 'beauty_food_consumable'; }\nelse if (/electronic|gadget|tech|appliance/.test(cats)) { delayDays = 10; categoryType = 'electronics'; }\nreturn [{ json: {\n  delayDays, categoryType,\n  orderId: order.id,\n  customerName: order.billing.first_name + ' ' + order.billing.last_name,\n  customerEmail: order.billing.email,\n  lineItems: (order.line_items || []).map(i => i.name).join(', ')\n} }];"
      },
