      "id": "2d91ca56-561f-4edb-afcc-4b5160097b21",
      "name": "Get Pending Reviews",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        -1472,
        1072
      ]
    },
    {
      "parameters": {
        "jsCode": "const reviewsResp = $('Fetch Google Business Reviews').first().json;\nconst reviews = reviewsResp.reviews || [];\nconst pending = $('Get Pending Reviews').all().map(i => i.json);\nfunction normalize(s){ return (s||'').toLowerCase().replace(/[^a-z ]/g,'').trim(); }\nfunction similar(a,b){ a=normalize(a); b=normalize(b); if(!a||!b) return 0; if(a===b) return 1; const aw=a.split(' '); const bw=b.split(' '); let hits=0; aw.forEach(w=>{ if(bw.includes(w) && w.length>1) hits++; }); return hits / Math.max(aw.length,bw.length); }\nconst matches = [];\nfor (const r of reviews) {\n  for (const p of pending) {\n    const score = similar(r.reviewer ? r.reviewer.displayName : '', p.customer_name);\n    const reviewTime = new Date(r.createTime);\n    const sentTime = new Date(p.email_sent_date);\n    if (score >= 0.6 && reviewTime > sentTime) {\n      matches.push({ json: { score, reviewerName: r.reviewer ? r.reviewer.displayName : '', orderId: p.order_id, customerName: p.customer_name, customerEmail: p.customer_email } });\n    }\n  }\n}\nreturn matches.length ? matches : [{ json: { score: 0 } }];"
      },
