      },
      "id": "6563fd6e-c217-4e94-b1d8-c80feaff4f45",
      "name": "Code: No Significant Change",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2752,
        1056
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Competitor price-change record (numeric threshold already crossed):\n{{ JSON.stringify($json) }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "Tum ek competitive-pricing analyst ho. Numeric threshold cross ho gaya hai, lekin tumhara kaam hai FALSE POSITIVES pakadna pehle alert bhejne se. send_alert=false karo agar: confidence < 0.5 (extraction shaky thi), currency mismatch lagti ho aur change ghair-mumkin tarah bohot extreme ho (e.g. >80% drop ek hi din me bina kisi clearance signal ke), ya price/currency parsing me clear glitch lagti ho. Warna send_alert=true karo. alert_priority: high agar price hum se kam ho gaya ya stock newly in_stock with big discount, medium agar generic drop, low agar sirf stock-status change ya minor discount. subject aur summary Roman Urdu + English mix me likho, short aur seedha, store owner ko actionable lage. recommended_action ek line ka practical suggestion ho."
        }
      },
      "id": "86d49799-bfb3-485a-b78c-af76638fef50",
      "name": "AI Agent: Compose Alert Decision",
