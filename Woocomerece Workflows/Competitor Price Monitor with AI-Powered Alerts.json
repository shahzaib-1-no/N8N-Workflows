    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"title\": { \"type\": \"string\" },\n    \"sku\": { \"type\": [\"string\", \"null\"] },\n    \"price\": { \"type\": [\"number\", \"null\"] },\n    \"currency\": { \"type\": [\"string\", \"null\"] },\n    \"original_price\": { \"type\": [\"number\", \"null\"] },\n    \"discount_percent\": { \"type\": [\"number\", \"null\"] },\n    \"stock_status\": { \"type\": \"string\", \"enum\": [\"in_stock\", \"out_of_stock\", \"limited_stock\", \"unknown\"] },\n    \"shipping_cost\": { \"type\": [\"number\", \"null\"] },\n    \"confidence\": { \"type\": \"number\" },\n    \"notes\": { \"type\": \"string\" }\n  },\n  \"required\": [\"title\", \"price\", \"stock_status\", \"confidence\"]\n}"
      },
      "id": "0c514d21-4037-4f48-87de-017cf7cf670d",
      "name": "Structured Output Parser: Extraction",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.2,
      "position": [
        848,
        752
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $('Loop Over Competitor URLs').item.json;\nconst scrape = $('Scrape Competitor Page (Firecrawl)').item.json;\nconst ai = $json; // parsed structured output from AI Agent\nconst det = (scrape.data && scrape.data.product) ? scrape.data.product : null;\nconst variant = det && det.variants && det.variants[0] ? det.variants[0] : null;\n\nlet price = ai.price, currency = ai.currency, stock_status = ai.stock_status;\nlet title = ai.title, sku = ai.sku, discount_percent = ai.discount_percent;\nlet extraction_source = 'ai';\n\nif (variant && variant.price && typeof variant.price.amount === 'number') {\n  price = variant.price.amount;\n  currency = variant.price.currency || currency;\n  stock_status = variant.availability && variant.availability.inStock === false ? 'out_of_stock' : 'in_stock';\n  title = det.title || title;\n  sku = variant.sku || sku;\n  if (variant.sale && variant.sale.originalPrice && typeof variant.sale.originalPrice.amount === 'number' && variant.sale.originalPrice.amount > 0) {\n    discount_percent = Math.round((1 - (price / variant.sale.originalPrice.amount)) * 1000) / 10;\n  }\n  extraction_source = 'deterministic+ai_shipping';\n}\n\nreturn { json: {\n  competitor_name: original.competitor_name,\n  product_url: original.product_url,\n  our_sku: original.our_sku,\n  store_url: original.store_url,\n  alert_threshold_percent: Number(original.alert_threshold_percent) || 5,\n  match_key: original.competitor_name + '|' + original.our_sku,\n  title: title,\n  sku: sku,\n  price: price,\n  currency: currency || 'USD',\n  discount_percent: discount_percent || 0,\n  stock_status: stock_status || 'unknown',\n  shipping_cost: ai.shipping_cost,\n  extraction_source: extraction_source,\n  confidence: ai.confidence,\n  scraped_at: new Date().toISOString(),\n} };"
      },
      "id": "490081b3-60e6-4e44-8c96-71cda9cf9f05",
