      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const record = $('Code: Reconcile & Normalize').item.json;\nconst wooResp = Array.isArray($json) ? $json : ($json.body || $json);\nconst wooArr = Array.isArray(wooResp) ? wooResp : (Array.isArray($json) ? $json : []);\nconst wooProduct = wooArr && wooArr.length ? wooArr[0] : null;\nconst ourPrice = wooProduct ? parseFloat(wooProduct.price) : null;\nlet diffVsUs = null;\nif (ourPrice && record.price) {\n  diffVsUs = Math.round(((ourPrice - record.price) / ourPrice) * 1000) / 10;\n}\nreturn { json: { ...record, our_price: ourPrice, price_diff_vs_us_percent: diffVsUs } };"
      },
      "id": "42c9ee0f-b2e6-4660-ba30-378c41e5c92e",
      "name": "Code: Merge Our Price + Diff",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1456,
        528
      ]
    },
    {
      "parameters": {
        "documentId": {
          "__rl": true,
          "value": "PUT_YOUR_GOOGLE_SHEET_ID_HERE",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "LatestSnapshot",
          "mode": "list",
          "cachedResultName": "LatestSnapshot"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "match_key",
              "lookupValue": "={{ $json.match_key }}"
            }
          ]
        },
        "options": {}
      },
      "id": "833c1227-2562-44b3-8ed8-0d5ea2a00ac7",
      "name": "Get Latest Snapshot",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1696,
        528
      ],
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const record = $('Code: Merge Our Price + Diff').item.json;\nconst snapRows = Array.isArray($json) ? $json : [];\nconst prev = snapRows.length ? snapRows[0] : null;\n\nlet changePercent = null, stockChanged = false, isNew = !prev;\nif (prev && prev.last_price) {\n  changePercent = Math.round(((parseFloat(prev.last_price) - record.price) / parseFloat(prev.last_price)) * 1000) / 10;\n  stockChanged = prev.last_stock_status && prev.last_stock_status !== record.stock_status;\n}\n\nconst threshold = record.alert_threshold_percent || 5;\n// price-drop / stock-change need a prior baseline to mean anything;\n// an active discount is a fact about THIS scrape and is worth flagging\n// even on the very first check for a competitor+sku pair.\nconst significant = (\n  (!isNew && changePercent !== null && changePercent >= threshold) ||\n  (!isNew && stockChanged) ||\n  (record.discount_percent && record.discount_percent > 0)\n);\n\nreturn { json: {\n  ...record,\n  previous_price: prev ? parseFloat(prev.last_price) : null,\n  previous_stock_status: prev ? prev.last_stock_status : null,\n  change_vs_previous_percent: changePercent,\n  stock_changed: stockChanged,\n  is_new_product: isNew,\n  significant_change: significant,\n} };"
      },
      "id": "ab8ed6bb-8641-4e77-93ac-e8bf5ec413de",
      "name": "Code: Calculate Change vs History",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
