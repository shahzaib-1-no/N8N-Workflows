    {
      "parameters": {
        "sendTo": "store-owner@example.com",
        "subject": "={{ $json.subject }}",
        "message": "=<p>{{ $json.summary }}</p><p><b>Competitor:</b> {{ $json.competitor_name }}<br><b>Product:</b> {{ $json.title }} ({{ $json.our_sku }})<br><b>Their price:</b> {{ $json.currency }} {{ $json.price }} (was {{ $json.previous_price }}, {{ $json.change_vs_previous_percent }}% change)<br><b>Our price:</b> {{ $json.our_price }} ({{ $json.price_diff_vs_us_percent }}% diff)<br><b>Stock:</b> {{ $json.stock_status }}<br><b>Priority:</b> {{ $json.alert_priority }}</p><p><b>Recommended action:</b> {{ $json.recommended_action }}</p><p><a href=\"{{ $json.product_url }}\">View competitor product page</a></p>",
