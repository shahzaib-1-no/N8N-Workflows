    {
      "parameters": {
        "promptType": "define",
        "text": "=Extract product data for a competitor price-monitoring system.\n\nRaw page markdown:\n{{ $json.data.markdown }}\n\nDeterministic structured data Firecrawl already parsed for this page (may be empty if the page wasn't recognised as a product page):\n{{ JSON.stringify($json.data.product || {}) }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "Tum ek e-commerce price extraction specialist ho. Goal: sirf ASLI selling price nikalo, MRP/list price/crossed-out price ko ignore karo jab tak woh khud current selling price na ho. Agar deterministic product data di gayi hai aur usme variants[0].price.amount maujood hai, USKO trust karo for price/currency/stock/sku/title - is data ko dobara guess mat karo. Tumhara real kaam hai: (1) shipping_cost dhoondo raw markdown text se (Firecrawl ka product format shipping cost capture nahi karta), (2) confirm karo ke koi extra/separate discount banner ya coupon deterministic data me reflect nahi hua, (3) agar deterministic data missing hai, tab tum khud markdown se price/title/sku/stock nikaalo - ads, related-product widgets aur MRP ko ignore karte hue. Confidence 0-1 do: 1.0 = deterministic data trusted, 0.5-0.8 = AI ne text se nikala but page clear thi, <0.5 = page confusing/ambiguous lagi. Currency missing ho to page ke locale se andaza lagao."
        }
      },
      "id": "0084a35d-ed67-4d3a-9645-c1569e25ba69",
      "name": "AI Agent: Extract Product Data",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.8,
      "position": [
        704,
        528
      ]
    },
    {
      "parameters": {
