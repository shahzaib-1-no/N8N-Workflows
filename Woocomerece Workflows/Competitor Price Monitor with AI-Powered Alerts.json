    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $('Loop Over Competitor URLs').item.json;\nconst resp = $json;\nlet errorType = 'unknown';\nconst msg = (resp.error || resp.message || '').toString().toLowerCase();\nif (msg.includes('429') || msg.includes('rate') || msg.includes('quota')) errorType = 'rate_limit_or_quota';\nelse if (msg.includes('401') || msg.includes('403') || msg.includes('auth')) errorType = 'auth_error';\nelse if (msg.includes('timeout')) errorType = 'timeout';\nreturn { json: {\n  timestamp: new Date().toISOString(),\n  competitor_name: original.competitor_name,\n  product_url: original.product_url,\n  error_type: errorType,\n  error_message: resp.error || resp.message || 'Scrape failed after 3 retries',\n} };"
      },
