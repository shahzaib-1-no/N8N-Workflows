      "id": "642fe2db-5a3d-4156-bbdf-a445c6fb8aea",
      "name": "Get Our Price (WooCommerce REST)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        528
      ],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000,
