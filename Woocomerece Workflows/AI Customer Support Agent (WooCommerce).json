    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const store = $('Lookup Store Config').item.json || {};\nconst input = $('Normalize Input').item.json;\n\nif (!store || !store.wc_consumer_key) {\n  return { ...input, storeFound: false };\n}\n\nconst authString = Buffer.from(`${store.wc_consumer_key}:${store.wc_consumer_secret}`).toString('base64');\n\nreturn {\n  ...input,\n  storeFound: true,\n  wcBaseUrl: `${store.wc_base_url}/wp-json/wc/v3`,\n  wcAuthHeader: `Basic ${authString}`,\n  supportTeamEmail: store.support_team_email || '',\n  aiPersona: store.ai_persona || '',\n  waPhoneNumberId: store.wa_phone_number_id || ''\n};"
      },
      "id": "8e6689e4-5e18-45cf-a313-962dc559ffb9",
