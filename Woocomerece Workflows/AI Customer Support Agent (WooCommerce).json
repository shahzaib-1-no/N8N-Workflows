      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"reply\": {\n      \"type\": \"string\",\n      \"description\": \"Customer-facing reply, friendly and clear, no markdown\"\n    },\n    \"intent\": {\n      \"type\": \"string\",\n      \"enum\": [\n        \"order_status\",\n        \"tracking_info\",\n        \"refund_request\",\n        \"cancellation_request\",\n        \"general_support\"\n      ]\n    },\n    \"verified\": {\n      \"type\": \"boolean\",\n      \"description\": \"true only if order/customer identity was confirmed against WooCommerce data\"\n    },\n    \"escalate\": {\n      \"type\": \"boolean\"\n    },\n    \"escalate_reason\": {\n      \"type\": \"string\",\n      \"description\": \"empty string if escalate is false\"\n    }\n  },\n  \"required\": [\n    \"reply\",\n    \"intent\",\n    \"verified\",\n    \"escalate\",\n    \"escalate_reason\"\n  ]\n}"
      },
      "id": "f82d3d96-e18c-4180-83b5-961d4f2b86ed",
      "name": "Response Schema",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.2,
