    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json;\nconst parsed = (raw.output && typeof raw.output === 'object') ? raw.output : raw;\nconst ctx = $('Build Auth Context').item.json;\n\nreturn {\n  channel: ctx.channel,\n  customerEmail: ctx.customerEmail,\n  customerPhone: ctx.customerPhone,\n  supportTeamEmail: ctx.supportTeamEmail,\n  waPhoneNumberId: ctx.waPhoneNumberId,\n  reply: parsed.reply || 'Sorry, I could not process that just now. A human agent will follow up shortly.',\n  intent: parsed.intent || 'general_support',\n  verified: !!parsed.verified,\n  escalate: !!parsed.escalate,\n  escalateReason: parsed.escalate_reason || ''\n};"
      },
