    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\nconst total = items.length;\nconst success = items.filter(i => i.status === 'success').length;\nconst couponFailed = items.filter(i => i.status === 'coupon_failed').length;\nconst emailFailed = items.filter(i => i.status === 'email_failed').length;\n\nreturn [{\n  json: {\n    runDate: new Date().toISOString(),\n    totalInactiveCustomers: total,\n    couponsSentSuccessfully: success,\n    couponCreationFailures: couponFailed,\n    emailSendFailures: emailFailed,\n  }\n}];"
      },
