    {
      "parameters": {
        "jsCode": "const PAID_STATUSES = ['completed', 'processing', 'on-hold'];\nconst customerMap = {};\n\nfor (const item of $input.all()) {\n  const order = item.json;\n  if (!PAID_STATUSES.includes(order.status)) continue;\n\n  const billing = order.billing || {};\n  if (!billing.email) continue; // can't coupon/email a customer with no address on file\n\n  const key = (order.customer_id && order.customer_id !== 0)\n    ? `cust_${order.customer_id}`\n    : `email_${billing.email.toLowerCase()}`;\n\n  const orderDate = new Date(order.date_created);\n\n  if (!customerMap[key] || new Date(customerMap[key].lastOrderDate) < orderDate) {\n    customerMap[key] = {\n      customerKey: key,\n      customerId: order.customer_id || null,\n      email: billing.email,\n      firstName: billing.first_name || 'there',\n      lastName: billing.last_name || '',\n      lastOrderDate: order.date_created,\n    };\n  }\n}\n\nconst now = new Date();\nconst results = Object.values(customerMap).map((c) => {\n  const daysSince = Math.floor((now - new Date(c.lastOrderDate)) / (1000 * 60 * 60 * 24));\n  return { ...c, daysSinceLastOrder: daysSince };\n});\n\nreturn results.map((r) => ({ json: r }));"
      },
      "id": "fc633f34-f7f9-408d-a382-8cc47af44fac",
      "name": "Aggregate Last Order Per Customer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -352,
        416
      ]
